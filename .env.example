# Banco de dados Neon PostgreSQL (Project → Connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Segredo do Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# Necessário na Vercel/produção para o Auth.js confiar no host
AUTH_TRUST_HOST=true
